{
  "name": "tauri-e2e",
  "version": "0.0.0",
  "description": "Tauri example app for E2E testing of Zubridge functionality",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "pnpm clean:output && pnpx shx rm -rf ./node_modules pnpm-lock.yaml ./dist ./src-tauri/target",
    "clean:output": "pnpx shx rm -rf ./dist* ./out* ./src-tauri/target",
    "typecheck": "tsc --noEmit -p tsconfig.json --composite false",
    "dev:vite": "vite",
    "dev": "vite build && pnpm tauri dev",
    "dev:zustand-basic": "cross-env ZUBRIDGE_MODE=zustand-basic pnpm dev",
    "dev:zustand-handlers": "cross-env ZUBRIDGE_MODE=zustand-handlers pnpm dev",
    "dev:zustand-reducers": "cross-env ZUBRIDGE_MODE=zustand-reducers pnpm dev",
    "dev:redux": "cross-env ZUBRIDGE_MODE=redux pnpm dev",
    "dev:custom": "cross-env ZUBRIDGE_MODE=custom pnpm dev",
    "dev:ui": "cross-env WATCH_UI=true vite build && cross-env WATCH_UI=true pnpm tauri dev",
    "build": "pnpm run typecheck && pnpm build:zustand-basic",
    "build:zustand-basic": "cross-env ZUBRIDGE_MODE=zustand-basic vite build && cross-env ZUBRIDGE_MODE=zustand-basic pnpm tauri build -- --verbose"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@zubridge/apps-shared": "workspace:*",
    "@zubridge/core": "workspace:*",
    "@zubridge/tauri": "workspace:*",
    "@zubridge/ui": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.3",
    "@types/node": "24.8.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@zubridge/types": "workspace:*",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
