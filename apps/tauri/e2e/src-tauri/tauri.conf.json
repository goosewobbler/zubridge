{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "e2e-tauri",
  "version": "0.1.0",
  "identifier": "com.zubridge.e2e-tauri",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm vite dev",
    "beforeBuildCommand": "pnpm vite build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": [
          "'self'"
        ],
        "connect-src": [
          "'self'",
          "ipc:*",
          "plugin:*",
          "tauri:*"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "https://asset.localhost",
          "data:"
        ],
        "script-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ]
      },
      "capabilities": [
        "main-capability"
      ]
    },
    "windows": []
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
